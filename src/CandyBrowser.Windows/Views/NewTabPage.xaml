<UserControl x:Class="CandyBrowser.Windows.Views.NewTabPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                    MaxWidth="600" Margin="0,-60,0,0">
            <!-- Logo -->
            <TextBlock Text="🍬" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <TextBlock Text="CandyZoe 浏览器" FontSize="24" FontWeight="Bold"
                       Foreground="#333" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="快速、安全、易用" FontSize="14"
                       Foreground="#999" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <!-- Search Box -->
            <Border CornerRadius="24" BorderBrush="#D0D0D0" BorderThickness="1"
                    Background="White" Margin="0,0,0,30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" Opacity="0.12" ShadowDepth="2"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="🔍" FontSize="16"
                               VerticalAlignment="Center" Margin="16,0,8,0" Foreground="#999"/>
                    <TextBox x:Name="SearchBox" Grid.Column="1"
                             Background="Transparent" BorderThickness="0"
                             Padding="8,12" FontSize="15" VerticalContentAlignment="Center"
                             KeyDown="SearchBox_KeyDown"
                             Foreground="#333"/>
                    <Border Grid.Column="2" Width="40" Height="40" CornerRadius="20"
                            Background="#FF6B9D" Cursor="Hand" Margin="4,4,4,4"
                            MouseLeftButtonDown="SearchButton_Click">
                        <TextBlock Text="→" FontSize="18" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Quick Links -->
            <TextBlock Text="常用网站" FontSize="13" Foreground="#999"
                       HorizontalAlignment="Center" Margin="0,0,0,12"/>
            <WrapPanel HorizontalAlignment="Center" x:Name="QuickLinksPanel">
                <!-- Populated in code-behind -->
            </WrapPanel>
        </StackPanel>

        <!-- Footer -->
        <TextBlock Grid.Row="1" Text="© 2024 CandyZoe" FontSize="11"
                   Foreground="#CCC" HorizontalAlignment="Center" Margin="0,0,0,16"/>
    </Grid>
</UserControl>
