<Window x:Class="CandyBrowser.Windows.Views.FavoritesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="书签管理器" Height="600" Width="720"
        WindowStartupLocation="CenterOwner" Background="#FAFAFA"
        WindowStyle="SingleBorderWindow">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/DialogStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#222">
                <Run FontFamily="Segoe MDL2 Assets" Text="&#xE734;"/>
                <Run Text="  书签管理器" FontFamily="Microsoft YaHei UI"/>
            </TextBlock>
            <TextBlock Text="管理你的收藏网址，支持拖拽移动和批量操作" FontSize="12" Foreground="#888" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 搜索和操作栏 -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,8"
                BorderBrush="#E8E8E8" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" Grid.Column="0" Padding="10,7" FontSize="12"
                         Style="{StaticResource DialogTextBox}" TextChanged="SearchBox_TextChanged"/>
                <Button Grid.Column="1" Margin="8,0,4,0" Click="AddCurrentBtn_Click"
                        Style="{StaticResource PrimaryBtn}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="添加" FontFamily="Microsoft YaHei UI" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Click="NewFolderBtn_Click" Style="{StaticResource SecondaryBtn}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8F4;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="文件夹" FontFamily="Microsoft YaHei UI" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="3" Margin="4,0,0,0" Click="ExportBookmarksBtn_Click"
                        Style="{StaticResource SecondaryBtn}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="导出" FontFamily="Microsoft YaHei UI" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="3" Margin="4,0,0,0" Click="ImportBookmarksBtn_Click"
                        Style="{StaticResource SecondaryBtn}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8F3;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="导入" FontFamily="Microsoft YaHei UI" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- 批量操作栏 -->
        <Border Grid.Row="2" Background="#F0F7FF" CornerRadius="8" Padding="12" Margin="0,0,0,8"
                BorderBrush="#D0E4FF" BorderThickness="1">
            <DockPanel>
                <CheckBox x:Name="SelectAllCheckBox" Content="全选" DockPanel.Dock="Left"
                          Checked="SelectAll_Changed" Unchecked="SelectAll_Changed"
                          FontFamily="Microsoft YaHei UI" FontSize="13" VerticalAlignment="Center"/>
                <TextBlock x:Name="SelectedCountText" DockPanel.Dock="Left" Text="已选 0 项"
                           FontFamily="Microsoft YaHei UI" FontSize="12" Foreground="#666"
                           VerticalAlignment="Center" Margin="16,0,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Button Click="BatchMoveBtn_Click" Style="{StaticResource SecondaryBtn}" Margin="0,0,6,0" Padding="12,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="移动到" FontFamily="Microsoft YaHei UI" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="BatchDeleteBtn_Click" Style="{StaticResource DangerBtn}" Padding="12,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="删除选中" FontFamily="Microsoft YaHei UI" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 书签列表 -->
        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="4"
                BorderBrush="#E8E8E8" BorderThickness="1">
            <TreeView x:Name="FavoritesTree" BorderThickness="0" Background="Transparent"
                      AllowDrop="True" Drop="Tree_Drop" DragOver="Tree_DragOver"
                      PreviewKeyDown="FavoritesTree_PreviewKeyDown">
                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="True"/>
                        <Setter Property="Padding" Value="4,3"/>
                        <Setter Property="FontSize" Value="13"/>
                        <EventSetter Event="MouseRightButtonDown" Handler="TreeViewItem_MouseRightButtonDown"/>
                        <EventSetter Event="MouseMove" Handler="TreeItem_MouseMove"/>
                        <EventSetter Event="Drop" Handler="TreeItem_Drop"/>
                        <EventSetter Event="DragOver" Handler="Tree_DragOver"/>
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>
        </Border>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Click="OpenBtn_Click" Width="90" Style="{StaticResource PrimaryBtn}" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="打开" FontFamily="Microsoft YaHei UI" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Click="EditBtn_Click" Width="90" Style="{StaticResource SecondaryBtn}" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="编辑" FontFamily="Microsoft YaHei UI" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Click="DeleteBtn_Click" Width="90" Style="{StaticResource DangerBtn}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBlock Text="删除" FontFamily="Microsoft YaHei UI" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
