<UserControl x:Class="CandyBrowser.Windows.Views.BookmarkSidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CandyBrowser.Windows.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="280">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12,8" Background="#F0F0F0">
            <Grid>
                <TextBlock Text="书签" FontSize="14" FontWeight="SemiBold" Foreground="#333"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="+" ToolTip="添加书签" Click="AddBookmark_Click"
                            Background="Transparent" BorderThickness="0" Foreground="#FF6B9D"
                            FontSize="16" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Search -->
        <TextBox Grid.Row="1" x:Name="SearchBox" Margin="8,8,8,0"
                 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                 Padding="8,6" FontSize="13"/>

        <!-- Bookmarks Tree -->
        <TreeView Grid.Row="2" x:Name="BookmarksTree"
                  ItemsSource="{Binding Bookmarks}"
                  Background="Transparent" BorderThickness="0" Margin="0,8,0,0"
                  SelectedItemChanged="BookmarksTree_SelectedItemChanged">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}"
                                          DataType="{x:Type vm:BookmarkItemViewModel}">
                    <StackPanel Orientation="Horizontal" Margin="0,2" Cursor="Hand"
                                MouseRightButtonDown="BookmarkItem_MouseRightButtonDown">
                        <TextBlock Text="{Binding Icon}" FontSize="14" Margin="0,0,6,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" Foreground="#333"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>

        <!-- Context Menu -->
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="在新标签页中打开" Click="OpenInNewTab_Click"/>
                <Separator/>
                <MenuItem Header="编辑" Click="EditBookmark_Click"/>
                <MenuItem Header="删除" Click="DeleteBookmark_Click"/>
                <Separator/>
                <MenuItem Header="新建书签" Click="AddBookmark_Click"/>
                <MenuItem Header="新建文件夹" Click="NewFolder_Click"/>
            </ContextMenu>
        </Grid.ContextMenu>
    </Grid>
</UserControl>
