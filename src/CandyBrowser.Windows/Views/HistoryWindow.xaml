<Window x:Class="CandyBrowser.Windows.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="历史记录" Height="400" Width="500"
        WindowStartupLocation="CenterOwner" Background="White">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="历史记录" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="清除" Margin="12,0,0,0" Click="ClearBtn_Click" Padding="8,4"/>
        </StackPanel>
        <ListBox x:Name="HistoryList"/>
    </DockPanel>
</Window>
