<Window x:Class="CandyBrowser.Windows.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="历史记录" Height="500" Width="600"
        WindowStartupLocation="CenterOwner" Background="White">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <DockPanel>
                <TextBlock Text="历史记录" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" DockPanel.Dock="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Button Content="清除全部" Click="ClearBtn_Click" Padding="10,5"
                            Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </DockPanel>
            <TextBox x:Name="SearchBox" Margin="0,8,0,0" Padding="8,5" FontSize="12"
                     BorderBrush="#DDD" TextChanged="SearchBox_TextChanged"/>
        </StackPanel>
        <ListBox x:Name="HistoryList" BorderThickness="1" BorderBrush="#E0E0E0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4">
                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Url}" FontSize="11" Foreground="#0078D4"
                                       TextTrimming="CharacterEllipsis" MaxWidth="400"/>
                            <TextBlock Text="{Binding VisitedAt, StringFormat='  {0:MM-dd HH:mm}'}"
                                       FontSize="10" Foreground="#999" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
