<Window x:Class="CandyBrowser.Windows.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="历史记录" Height="600" Width="720"
        WindowStartupLocation="CenterOwner" Background="#FAFAFA">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/DialogStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#222">
                <Run FontFamily="Segoe MDL2 Assets" Text="&#xE81C;"/>
                <Run Text="  历史记录" FontFamily="Microsoft YaHei UI"/>
            </TextBlock>
            <TextBlock Text="查看你的浏览记录，点击可打开，勾选可批量操作" FontSize="12" Foreground="#888" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 搜索和操作栏 -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,8"
                BorderBrush="#E8E8E8" BorderThickness="1">
            <DockPanel>
                <Button Click="ClearBtn_Click" DockPanel.Dock="Right"
                        Style="{StaticResource DangerBtn}" Margin="8,0,0,0" Padding="12,5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="清除全部" FontFamily="Microsoft YaHei UI" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <TextBox x:Name="SearchBox" Style="{StaticResource DialogTextBox}"
                         TextChanged="SearchBox_TextChanged"/>
            </DockPanel>
        </Border>

        <!-- 批量操作栏 -->
        <Border Grid.Row="2" Background="#F0F7FF" CornerRadius="8" Padding="12" Margin="0,0,0,8"
                BorderBrush="#D0E4FF" BorderThickness="1">
            <DockPanel>
                <CheckBox x:Name="SelectAllCheckBox" Content="全选" DockPanel.Dock="Left"
                          Checked="SelectAll_Changed" Unchecked="SelectAll_Changed"
                          FontFamily="Microsoft YaHei UI" FontSize="13" VerticalAlignment="Center"/>
                <TextBlock x:Name="SelectedCountText" DockPanel.Dock="Left" Text="已选 0 项"
                           FontFamily="Microsoft YaHei UI" FontSize="12" Foreground="#666"
                           VerticalAlignment="Center" Margin="16,0,0,0"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Button Click="BatchOpenBtn_Click" Style="{StaticResource PrimaryBtn}" Margin="0,0,6,0" Padding="12,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="打开选中" FontFamily="Microsoft YaHei UI" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Click="BatchDeleteBtn_Click" Style="{StaticResource DangerBtn}" Padding="12,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="删除选中" FontFamily="Microsoft YaHei UI" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 历史列表 -->
        <Border Grid.Row="3" Background="White" CornerRadius="8" Padding="4"
                BorderBrush="#E8E8E8" BorderThickness="1">
            <ListBox x:Name="HistoryList" BorderThickness="0" Background="Transparent"
                     SelectionMode="Extended"/>
        </Border>

        <!-- 底部提示 -->
        <TextBlock Grid.Row="4" Text="提示：点击记录可直接打开对应网页" 
                   FontSize="11" Foreground="#888" FontFamily="Microsoft YaHei UI"
                   Margin="0,8,0,0"/>
    </Grid>
</Window>
