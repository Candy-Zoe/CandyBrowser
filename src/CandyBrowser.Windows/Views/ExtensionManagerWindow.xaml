<Window x:Class="CandyBrowser.Windows.Views.ExtensionManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="扩展管理器 - CandyZoe浏览器" Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <Grid>
                <StackPanel>
                    <TextBlock Text="扩展管理器" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="管理您的浏览器扩展" FontSize="13"
                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Content="加载已解压的扩展" Click="LoadExtension_Click"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Padding="12,6" Background="#FF6B9D" Foreground="White" BorderThickness="0"/>
            </Grid>
        </StackPanel>

        <!-- Extensions List -->
        <ListBox Grid.Row="1" x:Name="ExtensionsList"
                 ItemsSource="{Binding Extensions}"
                 Background="Transparent" BorderThickness="0"
                 SelectionChanged="ExtensionsList_SelectionChanged">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="详情" Click="ExtensionDetails_Click"/>
                    <Separator/>
                    <MenuItem Header="移除" Click="ExtensionRemove_Click"/>
                </ContextMenu>
            </ListBox.ContextMenu>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12,12" Margin="0,0,0,8"
                            Background="{DynamicResource SidebarBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Icon -->
                            <Border Grid.Column="0" Width="40" Height="40"
                                    Background="{DynamicResource ToolbarBackgroundBrush}"
                                    CornerRadius="8" VerticalAlignment="Top">
                                <TextBlock Text="🧩" FontSize="20"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <!-- Info -->
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="{Binding Version}" FontSize="12"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <TextBlock Text="{Binding Description}" FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Toggle -->
                            <CheckBox Grid.Column="2" IsChecked="{Binding IsEnabled}"
                                      VerticalAlignment="Center"
                                      Checked="ExtensionToggle_Checked"
                                      Unchecked="ExtensionToggle_Unchecked"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
