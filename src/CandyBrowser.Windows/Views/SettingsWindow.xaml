<Window x:Class="CandyBrowser.Windows.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="设置 - CandyZoe浏览器" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧菜单 -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <StackPanel Margin="0,16,0,0">
                <TextBlock Text="设置" FontSize="20" FontWeight="Bold" Margin="16,0,0,24"
                           Foreground="{DynamicResource TextBrush}"/>

                <ListBox x:Name="SettingsMenu" SelectionChanged="SettingsMenu_SelectionChanged"
                         Background="Transparent" BorderThickness="0">
                    <ListBoxItem Content="常规" Tag="General" IsSelected="True"/>
                    <ListBoxItem Content="外观" Tag="Appearance"/>
                    <ListBoxItem Content="隐私和安全" Tag="Privacy"/>
                    <ListBoxItem Content="搜索引擎" Tag="Search"/>
                    <ListBoxItem Content="关于" Tag="About"/>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- 右侧内容 -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="24">
            <StackPanel x:Name="SettingsContent">
                <!-- 常规设置 -->
                <StackPanel x:Name="GeneralSettings">
                    <TextBlock Text="常规" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"
                               Foreground="{DynamicResource TextBrush}"/>

                    <!-- 启动时 -->
                    <TextBlock Text="启动时打开" FontSize="14" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextBrush}"/>
                    <ComboBox x:Name="StartupComboBox" Width="300" HorizontalAlignment="Left" Margin="0,0,0,20">
                        <ComboBoxItem Content="主页" Tag="homepage"/>
                        <ComboBoxItem Content="新标签页" Tag="newtab"/>
                        <ComboBoxItem Content="上次访问的页面" Tag="restore"/>
                    </ComboBox>

                    <!-- 主页 -->
                    <TextBlock Text="主页地址" FontSize="14" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBox x:Name="HomepageTextBox" Width="400" HorizontalAlignment="Left" Margin="0,0,0,20"
                             Style="{StaticResource AddressBarStyle}"/>

                    <!-- 新标签页 -->
                    <TextBlock Text="新标签页地址" FontSize="14" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBox x:Name="NewTabTextBox" Width="400" HorizontalAlignment="Left" Margin="0,0,0,20"
                             Style="{StaticResource AddressBarStyle}"/>

                    <!-- 下载 -->
                    <CheckBox x:Name="AskDownloadLocationCheckBox" Content="下载前询问每个文件的保存位置"
                              IsChecked="True" Margin="0,0,0,8"/>
                    <TextBlock Text="默认下载位置" FontSize="14" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextBrush}"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="DownloadPathTextBox" Grid.Column="0" Width="350"
                                 Style="{StaticResource AddressBarStyle}" IsReadOnly="True"/>
                        <Button Grid.Column="1" Content="浏览..." Margin="8,0,0,0"
                                Padding="12,6" Click="BrowseDownloadPath_Click"/>
                    </Grid>

                    <Separator Margin="0,16,0,16" Background="{DynamicResource BorderBrush}"/>

                    <Button Content="保存设置" Width="120" HorizontalAlignment="Left"
                            Padding="12,8" Click="SaveGeneralSettings_Click"
                            Background="#FF6B9D" Foreground="White" BorderThickness="0"/>
                </StackPanel>

                <!-- 外观设置 -->
                <StackPanel x:Name="AppearanceSettings" Visibility="Collapsed">
                    <TextBlock Text="外观" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"
                               Foreground="{DynamicResource TextBrush}"/>

                    <!-- 主题 -->
                    <TextBlock Text="主题" FontSize="14" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <RadioButton Content="浅色" Margin="0,0,16,0" IsChecked="True"
                                     GroupName="Theme" Tag="light"/>
                        <RadioButton Content="深色" Margin="0,0,16,0" GroupName="Theme" Tag="dark"/>
                        <RadioButton Content="跟随系统" GroupName="Theme" Tag="system"/>
                    </StackPanel>

                    <!-- 字体大小 -->
                    <TextBlock Text="页面字体大小" FontSize="14" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextBrush}"/>
                    <Slider x:Name="FontSizeSlider" Width="300" HorizontalAlignment="Left"
                            Minimum="12" Maximum="24" Value="16" TickFrequency="2"
                            IsSnapToTickEnabled="True" Margin="0,0,0,20"/>
                    <TextBlock x:Name="FontSizeLabel" Text="16px" FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,20"/>

                    <!-- 显示书签栏 -->
                    <CheckBox x:Name="ShowBookmarksBarCheckBox" Content="显示书签栏"
                              IsChecked="True" Margin="0,0,0,20"/>

                    <!-- 显示状态栏 -->
                    <CheckBox x:Name="ShowStatusBarCheckBox" Content="显示状态栏"
                              IsChecked="True" Margin="0,0,0,20"/>

                    <Separator Margin="0,16,0,16" Background="{DynamicResource BorderBrush}"/>

                    <Button Content="保存设置" Width="120" HorizontalAlignment="Left"
                            Padding="12,8" Click="SaveAppearanceSettings_Click"
                            Background="#FF6B9D" Foreground="White" BorderThickness="0"/>
                </StackPanel>

                <!-- 隐私和安全设置 -->
                <StackPanel x:Name="PrivacySettings" Visibility="Collapsed">
                    <TextBlock Text="隐私和安全" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"
                               Foreground="{DynamicResource TextBrush}"/>

                    <!-- 清除浏览数据 -->
                    <TextBlock Text="清除浏览数据" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"
                               Foreground="{DynamicResource TextBrush}"/>

                    <CheckBox Content="浏览历史记录" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox Content="Cookie 和其他网站数据" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox Content="缓存的图片和文件" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox Content="密码" IsChecked="False" Margin="0,0,0,8"/>
                    <CheckBox Content="自动填充表单数据" IsChecked="False" Margin="0,0,0,16"/>

                    <Button Content="清除数据" Width="120" HorizontalAlignment="Left"
                            Padding="12,8" Click="ClearBrowsingData_Click"
                            Background="#FF6B9D" Foreground="White" BorderThickness="0"
                            Margin="0,0,0,24"/>

                    <Separator Margin="0,0,0,16" Background="{DynamicResource BorderBrush}"/>

                    <!-- 密码管理 -->
                    <TextBlock Text="密码管理" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"
                               Foreground="{DynamicResource TextBrush}"/>

                    <CheckBox x:Name="OfferToSavePasswordsCheckBox" Content="提示保存密码"
                              IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox x:Name="AutoFillPasswordsCheckBox" Content="自动填充密码"
                              IsChecked="False" Margin="0,0,0,16"/>

                    <Button Content="管理已保存的密码" Width="160" HorizontalAlignment="Left"
                            Padding="12,8" Click="ManagePasswords_Click"
                            Background="Transparent" Foreground="{DynamicResource TextBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>

                    <Separator Margin="0,24,0,16" Background="{DynamicResource BorderBrush}"/>

                    <!-- 隐私设置 -->
                    <TextBlock Text="其他隐私设置" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"
                               Foreground="{DynamicResource TextBrush}"/>

                    <CheckBox Content="发送'不跟踪'请求" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox Content="启用安全 DNS" IsChecked="True" Margin="0,0,0,8"/>
                    <CheckBox Content="使用安全 DNS 解析程序" IsChecked="True" Margin="0,0,0,20"/>
                </StackPanel>

                <!-- 搜索引擎设置 -->
                <StackPanel x:Name="SearchSettings" Visibility="Collapsed">
                    <TextBlock Text="搜索引擎" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"
                               Foreground="{DynamicResource TextBrush}"/>

                    <TextBlock Text="默认搜索引擎" FontSize="14" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextBrush}"/>
                    <ComboBox x:Name="SearchEngineComboBox" Width="300" HorizontalAlignment="Left" Margin="0,0,0,20">
                        <ComboBoxItem Content="必应" Tag="https://www.bing.com/search?q={0}"/>
                        <ComboBoxItem Content="Google" Tag="https://www.google.com/search?q={0}"/>
                        <ComboBoxItem Content="百度" Tag="https://www.baidu.com/s?wd={0}"/>
                        <ComboBoxItem Content="DuckDuckGo" Tag="https://duckduckgo.com/?q={0}"/>
                        <ComboBoxItem Content="自定义" Tag="custom"/>
                    </ComboBox>

                    <TextBlock Text="自定义搜索引擎 URL (使用 {0} 作为搜索词占位符)" FontSize="14" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBox x:Name="CustomSearchEngineTextBox" Width="400" HorizontalAlignment="Left"
                             Style="{StaticResource AddressBarStyle}" IsEnabled="False"/>

                    <Separator Margin="0,16,0,16" Background="{DynamicResource BorderBrush}"/>

                    <Button Content="保存设置" Width="120" HorizontalAlignment="Left"
                            Padding="12,8" Click="SaveSearchSettings_Click"
                            Background="#FF6B9D" Foreground="White" BorderThickness="0"/>
                </StackPanel>

                <!-- 关于 -->
                <StackPanel x:Name="AboutSettings" Visibility="Collapsed">
                    <TextBlock Text="关于 CandyZoe浏览器" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"
                               Foreground="{DynamicResource TextBrush}"/>

                    <Border Background="{DynamicResource SidebarBackgroundBrush}"
                            CornerRadius="8" Margin="0,0,0,20" Padding="20">
                        <StackPanel>
                            <TextBlock Text="🍬" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="CandyZoe浏览器" FontSize="20" FontWeight="Bold"
                                       HorizontalAlignment="Center" Foreground="{DynamicResource TextBrush}"/>
                            <TextBlock Text="版本 0.1.0" FontSize="14" HorizontalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="一款跨平台的现代浏览器，基于 Edge Chromium 内核。" FontSize="14"
                               Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" Margin="0,0,0,20"/>

                    <TextBlock Text="功能特性：" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="• 多标签页浏览" FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="• 书签管理" FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="• 浏览历史记录" FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="• 密码管理器" FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="• 扩展支持" FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="• 阅读模式" FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="• 内置 PDF 阅读器" FontSize="13" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,20"/>

                    <TextBlock Text="技术栈：" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="• Windows: WPF + .NET 8 + WebView2" FontSize="13" 
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="• Android: Kotlin + Jetpack Compose" FontSize="13"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,20"/>

                    <TextBlock Text="© 2024 CandyZoe. 保留所有权利。" FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
