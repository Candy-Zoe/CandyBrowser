<Window x:Class="CandyBrowser.Windows.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="480" Width="500"
        WindowStartupLocation="CenterOwner" Background="White">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="设置" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>

            <TextBlock Text="基本设置" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#333"/>
            <TextBlock Text="主页地址:" Margin="0,0,0,4"/>
            <TextBox x:Name="HomepageBox" Width="400" Margin="0,0,0,8" Padding="6,4" HorizontalAlignment="Left"/>
            <TextBlock Text="搜索引擎 (用{0}代替搜索词):" Margin="0,0,0,4"/>
            <TextBox x:Name="SearchBox" Width="400" Margin="0,0,0,8" Padding="6,4" HorizontalAlignment="Left"/>

            <CheckBox x:Name="BookmarksCheck" Content="显示书签栏" Margin="0,0,0,6"/>
            <CheckBox x:Name="StartupContinueCheck" Content="启动时恢复上次未关闭的标签页" Margin="0,0,0,6"/>
            <CheckBox x:Name="StartupHomeCheck" Content="启动时打开主页" Margin="0,0,0,12"/>

            <TextBlock Text="外观" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#333"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="主题颜色:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <RadioButton x:Name="ThemeLight" Content="浅色" Margin="0,0,12,0" GroupName="Theme"/>
                <RadioButton x:Name="ThemeDark" Content="深色" GroupName="Theme"/>
            </StackPanel>

            <TextBlock Text="隐私" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" Foreground="#333"/>
            <CheckBox x:Name="DoNotTrackCheck" Content="发送 Do Not Track 请求头" Margin="0,0,0,6"/>
            <CheckBox x:Name="BlockPopupsCheck" Content="阻止弹出窗口" Margin="0,0,0,6"/>
            <CheckBox x:Name="ClearOnExitCheck" Content="退出时清除浏览数据" Margin="0,0,0,12"/>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="保存" Width="80" Height="30" Click="SaveBtn_Click"
                        Background="#0078D4" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Margin="0,0,8,0"/>
                <Button Content="清除浏览数据" Width="100" Height="30" Click="ClearDataBtn_Click"
                        Background="#E74C3C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
