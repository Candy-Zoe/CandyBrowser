<Window x:Class="CandyBrowser.Windows.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="350" Width="450"
        WindowStartupLocation="CenterOwner" Background="White">
    <StackPanel Margin="20">
        <TextBlock Text="设置" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>
        <TextBlock Text="主页地址:" Margin="0,0,0,4"/>
        <TextBox x:Name="HomepageBox" Width="300" Margin="0,0,0,12"/>
        <TextBlock Text="搜索引擎 (用{0}代替搜索词):" Margin="0,0,0,4"/>
        <TextBox x:Name="SearchBox" Width="300" Margin="0,0,0,12"/>
        <CheckBox x:Name="BookmarksCheck" Content="显示书签栏" IsChecked="True" Margin="0,0,0,8"/>
        <Button Content="保存" Width="80" Height="28" Click="SaveBtn_Click" Margin="0,12,0,0"/>
    </StackPanel>
</Window>
