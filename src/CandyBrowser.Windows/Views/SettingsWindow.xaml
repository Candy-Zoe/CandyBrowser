<Window x:Class="CandyBrowser.Windows.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Height="500" Width="520"
        WindowStartupLocation="CenterOwner" Background="#FAFAFA">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Resources/DialogStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#222" Margin="0,0,0,20">
                <Run FontFamily="Segoe MDL2 Assets" Text="&#xE713;"/>
                <Run Text="  设置" FontFamily="Microsoft YaHei UI"/>
            </TextBlock>

            <!-- 基本设置 -->
            <TextBlock Text="基本设置" Style="{StaticResource SectionTitle}"/>
            <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                    BorderBrush="#E8E8E8" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="主页地址" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                    <TextBox x:Name="HomepageBox" Style="{StaticResource DialogTextBox}" Margin="0,0,0,12"/>
                    <TextBlock Text="搜索引擎 (用{0}代替搜索词)" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                    <TextBox x:Name="SearchBox" Style="{StaticResource DialogTextBox}" Margin="0,0,0,12"/>
                    <CheckBox x:Name="BookmarksCheck" Content="显示书签栏" Margin="0,0,0,6" FontSize="13"/>
                    <CheckBox x:Name="StartupContinueCheck" Content="启动时恢复上次未关闭的标签页" Margin="0,0,0,6" FontSize="13"/>
                    <CheckBox x:Name="StartupHomeCheck" Content="启动时打开主页" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- 外观 -->
            <TextBlock Text="外观" Style="{StaticResource SectionTitle}"/>
            <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                    BorderBrush="#E8E8E8" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="主题颜色:" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="13"/>
                    <RadioButton x:Name="ThemeLight" Content="浅色" Margin="0,0,16,0" GroupName="Theme" FontSize="13"/>
                    <RadioButton x:Name="ThemeDark" Content="深色" GroupName="Theme" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- 隐私 -->
            <TextBlock Text="隐私" Style="{StaticResource SectionTitle}"/>
            <Border Background="White" CornerRadius="8" Padding="16" Margin="0,0,0,16"
                    BorderBrush="#E8E8E8" BorderThickness="1">
                <StackPanel>
                    <CheckBox x:Name="DoNotTrackCheck" Content="发送 Do Not Track 请求头" Margin="0,0,0,6" FontSize="13"/>
                    <CheckBox x:Name="BlockPopupsCheck" Content="阻止弹出窗口" Margin="0,0,0,6" FontSize="13"/>
                    <CheckBox x:Name="ClearOnExitCheck" Content="退出时清除浏览数据" FontSize="13"/>
                </StackPanel>
            </Border>

            <!-- 操作 -->
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <Button Content="保存设置" Click="SaveBtn_Click" Width="100"
                        Style="{StaticResource PrimaryBtn}" Margin="0,0,10,0"/>
                <Button Content="清除浏览数据" Click="ClearDataBtn_Click" Width="120"
                        Style="{StaticResource DangerBtn}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
