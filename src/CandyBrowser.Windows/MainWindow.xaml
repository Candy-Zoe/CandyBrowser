<Window x:Class="CandyBrowser.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="CandyZoe浏览器" Height="768" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#ECECEC"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp">

    <Window.Resources>
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="16" Padding="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#D9D9D9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C4C4C4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标签栏 + 工具栏 -->
        <Border Grid.Row="0" Background="#DEE1E6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="4,4,4,0">
                    <DockPanel>
                        <Button x:Name="NewTabBtn" DockPanel.Dock="Left" Content="+"
                                Width="28" Height="28" FontSize="16"
                                Click="NewTabBtn_Click"
                                Style="{StaticResource NavBtn}"
                                ToolTip="新标签页 (Ctrl+T)" Margin="0,0,4,0"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="TabStrip" Orientation="Horizontal"/>
                        </ScrollViewer>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1" Padding="6,4">
                    <DockPanel>
                        <Button DockPanel.Dock="Left" Content="&#xE72B;" FontFamily="Segoe MDL2 Assets"
                                Click="BackBtn_Click" Style="{StaticResource NavBtn}" ToolTip="后退" Margin="0,0,1,0"/>
                        <Button DockPanel.Dock="Left" Content="&#xE72A;" FontFamily="Segoe MDL2 Assets"
                                Click="ForwardBtn_Click" Style="{StaticResource NavBtn}" ToolTip="前进" Margin="0,0,1,0"/>
                        <Button DockPanel.Dock="Left" Content="&#xE72C;" FontFamily="Segoe MDL2 Assets"
                                Click="ReloadBtn_Click" Style="{StaticResource NavBtn}" ToolTip="刷新 (F5)" Margin="0,0,4,0"/>
                        <Button DockPanel.Dock="Left" Content="&#xE80F;" FontFamily="Segoe MDL2 Assets"
                                Click="HomeBtn_Click" Style="{StaticResource NavBtn}" ToolTip="主页" Margin="0,0,6,0"/>

                        <Button DockPanel.Dock="Right" Content="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                Click="SettingsBtn_Click" Style="{StaticResource NavBtn}" ToolTip="设置" Margin="1,0,0,0"/>
                        <Button x:Name="DownloadBtn" DockPanel.Dock="Right" Content="&#xE896;"
                                FontFamily="Segoe MDL2 Assets"
                                Click="DownloadBtn_Click" Style="{StaticResource NavBtn}" ToolTip="下载 (Ctrl+J)" Margin="1,0,0,0"/>
                        <Button DockPanel.Dock="Right" Content="&#xE81C;" FontFamily="Segoe MDL2 Assets"
                                Click="HistoryBtn_Click" Style="{StaticResource NavBtn}" ToolTip="历史记录" Margin="1,0,0,0"/>
                        <Button x:Name="BookmarkStarBtn" DockPanel.Dock="Right" Content="&#xE734;"
                                FontFamily="Segoe MDL2 Assets"
                                Click="BookmarkBtn_Click" Style="{StaticResource NavBtn}" ToolTip="收藏当前页" Margin="1,0,0,0"/>
                        <Button DockPanel.Dock="Right" Content="&#xE71D;" FontFamily="Segoe MDL2 Assets"
                                Click="FavoritesBtn_Click" Style="{StaticResource NavBtn}" ToolTip="收藏夹" Margin="1,0,0,0"/>

                        <!-- 地址栏 (含安全指示) -->
                        <Border Background="White" CornerRadius="16" Padding="4,0,10,0"
                                Margin="0,0,6,0" BorderBrush="#D0D0D0" BorderThickness="1">
                            <DockPanel>
                                <TextBlock x:Name="SecurityIcon" Text="&#xE72E;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="12" Foreground="#999" VerticalAlignment="Center"
                                           Margin="6,0,4,0" DockPanel.Dock="Left" ToolTip="安全连接"/>
                                <TextBox x:Name="AddressBar" BorderThickness="0" Background="Transparent"
                                         VerticalContentAlignment="Center" FontSize="13"
                                         KeyDown="AddressBar_KeyDown" AcceptsReturn="False"
                                         GotKeyboardFocus="AddressBar_GotKeyboardFocus"/>
                            </DockPanel>
                        </Border>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>

        <!-- 书签栏 -->
        <Border x:Name="BookmarksBarBorder" Grid.Row="1" Background="#F5F5F5"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                Padding="8,3" Visibility="Visible">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="BookmarksBar" Orientation="Horizontal"/>
            </ScrollViewer>
        </Border>

        <!-- 网页内容 + 查找栏 -->
        <Grid x:Name="TabContentContainer" Grid.Row="2" Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 查找栏 -->
            <Border x:Name="FindBar" Grid.Row="0" Background="#F8F8F8" BorderBrush="#E0E0E0"
                    BorderThickness="0,0,0,1" Padding="8,4" Visibility="Collapsed">
                <DockPanel>
                    <Button Content="✕" DockPanel.Dock="Right" Width="24" Height="24" FontSize="10"
                            Click="CloseFindBar_Click" Style="{StaticResource NavBtn}" ToolTip="关闭查找"/>
                    <Button Content="&#xE72A;" FontFamily="Segoe MDL2 Assets" DockPanel.Dock="Right"
                            Click="FindNext_Click" Style="{StaticResource NavBtn}" ToolTip="下一个" Margin="0,0,2,0"/>
                    <Button Content="&#xE72B;" FontFamily="Segoe MDL2 Assets" DockPanel.Dock="Right"
                            Click="FindPrev_Click" Style="{StaticResource NavBtn}" ToolTip="上一个" Margin="0,0,2,0"/>
                    <TextBlock x:Name="FindMatchCount" DockPanel.Dock="Right" Text="" FontSize="11"
                               Foreground="#666" VerticalAlignment="Center" Margin="4,0"/>
                    <TextBox x:Name="FindBox" BorderThickness="1" BorderBrush="#D0D0D0" Padding="6,3"
                             FontSize="12" VerticalContentAlignment="Center"
                             KeyDown="FindBox_KeyDown" TextChanged="FindBox_TextChanged"/>
                </DockPanel>
            </Border>

            <!-- WebView2 -->
            <wv2:WebView2 x:Name="MainWebView" Grid.Row="1"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"/>

            <!-- 下载面板 -->
            <Border x:Name="DownloadPanel" Grid.Row="2" Background="#FAFAFA" BorderBrush="#E0E0E0"
                    BorderThickness="0,1,0,0" MaxHeight="200" Visibility="Collapsed">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F0F0F0" Padding="8,4">
                        <DockPanel>
                            <TextBlock Text="下载" FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center" DockPanel.Dock="Left"/>
                            <Button Content="✕" DockPanel.Dock="Right" Width="24" Height="24" FontSize="10"
                                    Click="CloseDownloadPanel_Click" Style="{StaticResource NavBtn}"/>
                        </DockPanel>
                    </Border>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="DownloadList" Margin="4"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="3" Background="#F0F0F0"
                BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                Padding="8,2" Opacity="0.95">
            <DockPanel>
                <TextBlock x:Name="StatusText" Text="" FontSize="11" Foreground="#666"
                           DockPanel.Dock="Left" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Button Content="&#xE738;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                            Click="ZoomOutBtn_Click" Width="22" Height="20"
                            Style="{StaticResource NavBtn}" ToolTip="缩小"/>
                    <TextBlock x:Name="ZoomText" Text="100%" FontSize="11" Foreground="#666"
                               VerticalAlignment="Center" Margin="2,0" Width="36" TextAlignment="Center"/>
                    <Button Content="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                            Click="ZoomInBtn_Click" Width="22" Height="20"
                            Style="{StaticResource NavBtn}" ToolTip="放大"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
