<Window x:Class="CandyBrowser.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CandyBrowser.Windows.Views"
        Title="CandyZoe浏览器" Height="768" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Window.InputBindings>
        <KeyBinding Key="T" Modifiers="Control" Command="{Binding NewTabCommand}"/>
        <KeyBinding Key="F5" Command="{Binding ReloadCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Tab Strip -->
        <Border Grid.Row="0" Background="#F5F5F5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="🍬" FontSize="16" Margin="12,8" VerticalAlignment="Center"/>

                <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Tabs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="2,4" Padding="8,4" CornerRadius="4"
                                        Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                                        Cursor="Hand" MinWidth="120" MaxWidth="200"
                                        MouseLeftButtonDown="Tab_MouseLeftButtonDown"
                                        MouseDown="Tab_MouseDown">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Title}" 
                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                                   Foreground="#333"/>
                                        <Button Grid.Column="1" Content="x" 
                                                Command="{Binding DataContext.CloseTabCommand, 
                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="#666" Cursor="Hand" Padding="4,2"
                                                MouseLeftButtonDown="TabClose_MouseLeftButtonDown"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Grid.Column="2" Content="+" Command="{Binding NewTabCommand}"
                        Background="Transparent" BorderThickness="0" FontSize="18"
                        Foreground="#666" Width="32" Height="28" Margin="4,4" Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,1">
            <Grid Margin="8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="←" Command="{Binding GoBackCommand}"
                        IsEnabled="{Binding CanGoBack}" Background="Transparent" BorderThickness="0"
                        Foreground="#333" Width="32" Height="28" Cursor="Hand" FontSize="16"/>
                <Button Grid.Column="1" Content="→" Command="{Binding GoForwardCommand}"
                        IsEnabled="{Binding CanGoForward}" Background="Transparent" BorderThickness="0"
                        Foreground="#333" Width="32" Height="28" Cursor="Hand" FontSize="16"/>
                <Button Grid.Column="2" Content="R" Command="{Binding ReloadCommand}"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#333" Width="32" Height="28" Cursor="Hand" FontSize="14"/>
                <Button Grid.Column="3" Content="Home" Command="{Binding OpenHomepageCommand}"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#333" Width="40" Height="28" Cursor="Hand" FontSize="12"/>

                <TextBox Grid.Column="4" x:Name="AddressBar" 
                         Text="{Binding AddressBarText, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="AddressBar_KeyDown"
                         GotFocus="AddressBar_GotFocus"
                         LostFocus="AddressBar_LostFocus"
                         Background="White" BorderBrush="#E0E0E0" BorderThickness="1"
                         Padding="8,6" FontSize="14" VerticalContentAlignment="Center"/>

                <Button Grid.Column="5" Content="*" Command="{Binding AddBookmarkCommand}"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#333" Width="32" Height="28" Cursor="Hand" FontSize="16"
                        ToolTip="添加书签"/>
                <Button Grid.Column="6" Content="B" Command="{Binding ToggleBookmarkSidebarCommand}"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#333" Width="32" Height="28" Cursor="Hand" FontSize="14"
                        ToolTip="书签栏"/>
                <Button Grid.Column="7" Content="H" Command="{Binding ToggleHistoryPanelCommand}"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#333" Width="32" Height="28" Cursor="Hand" FontSize="14"
                        ToolTip="历史记录"/>
                <Button Grid.Column="8" Content="S" Command="{Binding OpenSettingsCommand}"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#333" Width="32" Height="28" Cursor="Hand" FontSize="14"
                        ToolTip="设置"/>
            </Grid>
        </Border>

        <!-- Bookmarks Bar -->
        <Border x:Name="BookmarksBarBorder" Grid.Row="2"
                Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,1" Padding="8,2">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="BookmarksBarItems" Orientation="Horizontal"/>
            </ScrollViewer>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Width="250" 
                    Visibility="{Binding IsBookmarkSidebarVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="#F8F8F8" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <views:BookmarkSidebar x:Name="BookmarkSidebarControl"/>
            </Border>

            <views:BrowserView x:Name="BrowserViewControl" Grid.Column="1"/>

            <Border Grid.Column="2" Width="300"
                    Visibility="{Binding IsHistoryPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                    Background="#F8F8F8" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0">
                <views:HistoryPanel x:Name="HistoryPanelControl"/>
            </Border>
        </Grid>
    </Grid>
</Window>
