<Window x:Class="CandyBrowser.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CandyZoe浏览器" Height="768" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tab Strip -->
        <Border Grid.Row="0" Background="#D4D4D4" Padding="4">
            <DockPanel>
                <Button DockPanel.Dock="Left" Content="+" Width="28" Height="26" Click="NewTabBtn_Click"
                        FontSize="14" Margin="0,0,8,0" Cursor="Hand"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="TabStrip" Orientation="Horizontal"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Background="#E8E8E8" BorderBrush="#CCCCCC" BorderThickness="0,1" Padding="6,4">
            <DockPanel>
                <!-- Navigation buttons -->
                <Button DockPanel.Dock="Left" Content="←" Click="BackBtn_Click" Width="28" Height="26" Margin="0,0,2,0"/>
                <Button DockPanel.Dock="Left" Content="→" Click="ForwardBtn_Click" Width="28" Height="26" Margin="0,0,2,0"/>
                <Button DockPanel.Dock="Left" Content="⟳" Click="ReloadBtn_Click" Width="28" Height="26" Margin="0,0,8,0"/>
                <Button DockPanel.Dock="Left" Content="🏠" Click="HomeBtn_Click" Width="28" Height="26" Margin="0,0,8,0"/>

                <!-- Address Bar -->
                <TextBox x:Name="AddressBar" Height="26" VerticalContentAlignment="Center"
                         KeyDown="AddressBar_KeyDown" AcceptsReturn="False"
                         Margin="0,0,8,0"/>

                <!-- Action buttons -->
                <Button DockPanel.Dock="Right" Content="⭐" Click="BookmarkBtn_Click" Width="28" Height="26" Margin="2,0,0,0" ToolTip="收藏当前页面"/>
                <Button DockPanel.Dock="Right" Content="📋" Click="HistoryBtn_Click" Width="28" Height="26" Margin="2,0,0,0" ToolTip="历史记录"/>
                <Button DockPanel.Dock="Right" Content="⚙" Click="SettingsBtn_Click" Width="28" Height="26" Margin="2,0,0,0" ToolTip="设置"/>
            </DockPanel>
        </Border>

        <!-- Bookmarks Bar -->
        <Border x:Name="BookmarksBarBorder" Grid.Row="2" Background="#ECECEC" BorderBrush="#CCCCCC"
                BorderThickness="0,1" Padding="4,2" Visibility="Visible">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="BookmarksBar" Orientation="Horizontal"/>
            </ScrollViewer>
        </Border>

        <!-- Tab Content -->
        <Grid x:Name="TabContentContainer" Grid.Row="3" Background="White"/>

        <!-- Status Bar -->
        <Border Grid.Row="4" Background="#E8E8E8" BorderBrush="#CCCCCC" BorderThickness="0,1" Padding="6,2">
            <DockPanel>
                <TextBlock x:Name="StatusText" Text="就绪" FontSize="11" DockPanel.Dock="Left" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                    <Button Content="−" Click="ZoomOutBtn_Click" Width="20" Height="18" FontSize="10" Margin="0,0,2,0"/>
                    <TextBlock x:Name="ZoomText" Text="100%" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" Width="36" TextAlignment="Center"/>
                    <Button Content="+" Click="ZoomInBtn_Click" Width="20" Height="18" FontSize="10"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
